    "express": "^5.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "pino": "^9.0.0",
    "pino-http": "^11.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.30",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.8",
    "pino-pretty": "^13.0.0",
