{
  "name": "api-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development PORT=5000 node --env-file=.env ./dist/index.mjs",
    "build": "node ./build.mjs",
